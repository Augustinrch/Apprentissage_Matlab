close all 
clear all 
 
% ---------------------------------------------------------
%  1. VECTEURS DE BASE
% ---------------------------------------------------------
 
% Créer un vecteur temps de 0 à 10s avec un pas de 0.01s
t = 0 : 0.01 : 10;          % vecteur temps (s)
 
% Créer une vitesse simulée (sinusoïdale autour de 50 km/h)
v = 50 + 30 * sin(t);       % vitesse (km/h)
 
% Créer une accélération longitudinale simulée
ax = 2 * cos(t);            % accélération (m/s²)
 
% Créer une accélération latérale simulée
ay = 1.5 * sin(2*t);        % accélération latérale (m/s²)
 

%  2. OPÉRATIONS DE BASE SUR LES VECTEURS
 
v_max   = max(v);           % vitesse maximale
v_min   = min(v);           % vitesse minimale
v_moy   = mean(v);          % vitesse moyenne
v_ms    = v / 3.6;          % conversion km/h → m/s
 
fprintf('--- Statistiques vitesse ---\n');
fprintf('Vmax  : %.2f km/h\n', v_max);
fprintf('Vmin  : %.2f km/h\n', v_min);
fprintf('Vmoy  : %.2f km/h\n', v_moy);
 

%  3. BOUCLE FOR — calcul manuel d'une moyenne

somme = 0;
for i = 1 : length(v)
    somme = somme + v(i);
end
v_moy_manuel = somme / length(v);
fprintf('Vmoy (boucle) : %.2f km/h\n', v_moy_manuel);
 
%  4. CONDITION IF
 
if v_max > 70
    fprintf('Vitesse max > 70 km/h — zone rouge\n');
elseif v_max > 50
    fprintf('Vitesse max entre 50 et 70 km/h — zone orange\n');
else
    fprintf('Vitesse max < 50 km/h — zone verte\n');
end
 

%  5. FONCTION
 
% Appel de la fonction
distance = calculer_distance(v_ms, t);
fprintf('Distance parcourue : %.2f m\n', distance(end));
 
% ---------------------------------------------------------
%  6. GRAPHES
% ---------------------------------------------------------
 
figure('Name', 'Jour 1 — Données simulées FS', 'NumberTitle', 'off');
 
% Graphe 1 : vitesse/temps
subplot(3,1,1);
plot(t, v, 'b-', 'LineWidth', 1.5);
xlabel('Temps (s)');
ylabel('Vitesse (km/h)');
title('Vitesse simulée');
grid on;
legend('Vitesse');
 
% Graphe 2 : accélérations
subplot(3,1,2);
plot(t, ax, 'r-', 'LineWidth', 1.5);
hold on;
plot(t, ay, 'g--', 'LineWidth', 1.5);
xlabel('Temps (s)');
ylabel('Accélération (m/s²)');
title('Accélérations longitudinale et latérale');
grid on;
legend('Ax (long)', 'Ay (lat)');
 
% Graphe 3 : carte G-G (scatter)
subplot(3,1,3);
scatter(ay, ax, 5, t, 'filled');
xlabel('Accélération latérale (m/s²)');
ylabel('Accélération longitudinale (m/s²)');
title('Carte G-G');
colorbar;
grid on;
 

%  FONCTION LOCALE
 
function d = calculer_distance(v_ms, t)
    % Intègre la vitesse pour obtenir la distance
    % v_ms : vitesse en m/s
    % t    : vecteur temps en s
    d = cumtrapz(t, v_ms);  % intégration trapézoïdale
end
 
